# ─────────────────────────────────────────────────────────────────────────────
# tc-ui — gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── 환경 변수 / API 키 (절대 커밋 금지) ────────────────────────────────────
.env

# ── Google Drive 인증 (개인 파일 — 절대 공유 금지) ──────────────────────────
credentials.json
.drive_token.json

# ── Google Drive 설정 (개인 폴더 ID 포함) ───────────────────────────────────
# config.example.json 을 복사해서 본인 설정으로 채우세요
# cp config.example.json config.json
config.json

# ── 런타임 생성 데이터 (재생성 가능, 커밋 불필요) ────────────────────────────
workspace/
specs/
outputs/

# ── 사용자 생성 TC 파일 (개인 프로젝트 데이터) ──────────────────────────────
# 빈 디렉토리 유지를 위해 .gitkeep 은 추적
tc_files/*
!tc_files/.gitkeep
projects.json

# ── 샘플 PDF (서버 시작 시 자동 생성되므로 커밋 불필요) ─────────────────────
static/

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.Python
.venv/

# ── macOS ───────────────────────────────────────────────────────────────────
.DS_Store

# ── R ───────────────────────────────────────────────────────────────────────
.Rhistory

# ── 구 버전 / 개인 테스트 파일 ──────────────────────────────────────────────
data/
guide/
guide_unpacked/
risk_policy_files/
risk_policy_files.zip
test_gemini_key.py
test_openai_key.py
