# ─────────────────────────────────────────────────────────────────────────────
# tc-agent — gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Python 가상환경 ──────────────────────────────────────────────────────────
.venv/
__pycache__/
*.pyc
*.pyo

# ── 생성된 출력물 바이너리 (재생성 가능) ────────────────────────────────────
phase*/outputs/*.xlsx
phase*/outputs/*.xls
phase*/outputs/*.pptx
phase*/outputs/*.ppt

# ── PDF 입력 기획서 (기밀/대용량 — 직접 재업로드) ───────────────────────────
phase*/workspace/*.pdf
phase*/_workspace/00_input/*.pdf

# ── Claude Code 내부 설정 ────────────────────────────────────────────────────
.agents/
.claude/skills/

# ── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble

# ── R ───────────────────────────────────────────────────────────────────────
.Rhistory

# ── IDE ─────────────────────────────────────────────────────────────────────
.vscode/settings.json
